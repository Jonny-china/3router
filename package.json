{
  "name": "3router",
  "version": "0.2.0",
  "private": false,
  "description": "本地 Claude Code API 智能路由代理 —— 按消息内容将请求路由到不同上游/模型，支持规则引擎、多上游、系统守护进程与 Web 管理面板。",
  "keywords": [
    "claude-code",
    "anthropic",
    "api-proxy",
    "llm",
    "router",
    "proxy",
    "typescript"
  ],
  "license": "MIT",
  "author": {
    "name": "Jonny Chen",
    "url": "https://github.com/Jonny-china"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jonny-china/3router.git"
  },
  "bugs": {
    "url": "https://github.com/Jonny-china/3router/issues"
  },
  "homepage": "https://github.com/Jonny-china/3router",
  "type": "module",
  "bin": {
    "3router": "bin/3router"
  },
  "files": [
    "bin/",
    "dist/",
    "dist-web/",
    "config.example.json"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "bun run --watch src/cli.ts serve",
    "typecheck": "tsc --noEmit",
    "build:cli": "tsdown",
    "build:web": "cd web && pnpm build",
    "build:copy-web": "rm -rf dist-web && cp -r web/dist dist-web",
    "build": "pnpm build:cli && pnpm build:web && pnpm build:copy-web",
    "prepublishOnly": "npm run typecheck && npm run build",
    "start": "node dist/cli.js serve",
    "test": "bun test",
    "lint": "oxlint src/ web/src/",
    "format": "oxfmt src/ web/src/",
    "format:check": "oxfmt --check src/ web/src/"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "bun-types": "^1.3.14",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  }
}
