#!/usr/bin/env node

// 3router 入口 shim：定位当前平台的预编译二进制（@3router/<platform>）并透传执行。
// 平台子包由主包 optionalDependencies 按 os/cpu 自动只装一个。
import { spawnSync } from "node:child_process";
import { createRequire } from "node:module";

const require = createRequire(import.meta.url);
const platform = `${process.platform}-${process.arch}`;
const pkg = `@3router/${platform}`;

let binPath;
try {
  binPath = require.resolve(pkg);
} catch {
  console.error(`错误: 找不到 3router 平台二进制（${pkg}）。`);
  console.error("");
  console.error("可能原因：");
  console.error("  1. 当前平台暂未提供预编译二进制");
  console.error("  2. 安装不完整，尝试: npm rebuild 3router");
  console.error("");
  console.error("或从 GitHub Release 直接下载: https://github.com/Jonny-china/3router/releases");
  process.exit(1);
}

const result = spawnSync(binPath, process.argv.slice(2), { stdio: "inherit" });
process.exit(result.status ?? 1);
